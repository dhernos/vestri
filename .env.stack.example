# Core stack
POSTGRES_USER=vestri
POSTGRES_PASSWORD=vestri
POSTGRES_DB=vestri
FRONTEND_PORT=3000
BACKEND_PORT=8080
APP_BASE_URL=http://localhost:3000

# Security / backend behavior
NODE_API_KEY_ENCRYPTION_KEY=change-me-to-a-strong-random-value
NO_EMAIL_VERIFY=true
AUTO_MIGRATE=true
TOTP_ISSUER=Vestri
TRUSTED_PROXIES=

# WebAuthn
WEB_AUTHN_ORIGIN=http://localhost:3000
WEB_AUTHN_RP_ID=localhost
WEB_AUTHN_RP_NAME=Auth Service
WEB_AUTHN_ORIGINS=http://localhost:3000

# Frontend runtime
NEXT_TELEMETRY_DISABLED=1

# Optional worker TLS trust overrides
WORKER_TLS_CA_CERT_FILE=

# Optional log tuning
LOG_MAX_SIZE_MB=5
LOG_MAX_BACKUPS=1

# Optional SMTP
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=
EMAIL_SERVER_SECURE=false

# Optional OAuth (GitHub)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=
