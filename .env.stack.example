# Core stack (required)
POSTGRES_USER=vestri
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vestri
FRONTEND_PORT=3000
BACKEND_PORT=8080
APP_BASE_URL=http://localhost:3000
# Optional: force Secure flag on session cookie (default auto: true if APP_BASE_URL is https)
SESSION_COOKIE_SECURE=
NODE_API_KEY_ENCRYPTION_KEY=change-me-to-a-strong-random-value

# WebAuthn (required for passkeys; match your frontend domain)
WEB_AUTHN_ORIGIN=http://localhost:3000
WEB_AUTHN_RP_ID=localhost
WEB_AUTHN_RP_NAME=Vestri
WEB_AUTHN_ORIGINS=http://localhost:3000

# Email (set all values to enable SMTP sending)
NO_EMAIL_VERIFY=false
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-smtp-user
EMAIL_SERVER_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@example.com
EMAIL_SERVER_SECURE=false

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=
